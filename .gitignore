# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage
*.lcov
.nyc_output

# Dependency directories
node_modules/
jspm_packages/
/.pnp
.pnp.js
.yarn/install-state.gz

# TypeScript cache
*.tsbuildinfo
next-env.d.ts

# Optional caches
.npm
.eslintcache
.stylelintcache
.node_repl_history

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.*
!.env.example
.env*.local

# Build output
.next/
/out/
/build
dist

# misc
.DS_Store
*.pem
.cache
.parcel-cache

# Vercel
.vercel

# Storybook
*storybook.log
storybook-static

# Cursor
.cursor-assets/
.cursor-figma-assets/

